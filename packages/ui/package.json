{
  "name": "@gitpm/ui",
  "version": "0.1.9",
  "license": "MIT",
  "description": "React web UI for gitpm — visualize and edit roadmaps, epics, and stories backed by the .meta/ tree",
  "keywords": [
    "gitpm",
    "project-management",
    "react",
    "ui",
    "roadmap"
  ],
  "homepage": "https://github.com/yevheniidehtiar/gitpm#readme",
  "bugs": {
    "url": "https://github.com/yevheniidehtiar/gitpm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yevheniidehtiar/gitpm.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "build:demo": "tsx scripts/bundle-demo-data.ts && VITE_DEMO_MODE=1 VITE_BASE=/gitpm/ vite build",
    "dev": "tsx src/dev.ts",
    "capture": "tsx scripts/capture.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@gitpm/core": "workspace:*",
    "@gitpm/sync-github": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-router": "^1.82.0",
    "@tanstack/react-virtual": "^3.13.23",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "hono": "^4.12.11",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "happy-dom": "^20.8.9",
    "playwright": "1.59.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "vite": "^8.0.5"
  }
}

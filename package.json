{
  "name": "gitpm-monorepo",
  "private": true,
  "license": "MIT",
  "description": "Git-native project management — monorepo root for gitpm",
  "homepage": "https://github.com/yevheniidehtiar/gitpm#readme",
  "bugs": {
    "url": "https://github.com/yevheniidehtiar/gitpm/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yevheniidehtiar/gitpm.git"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "dev:ui": "bun run --filter @gitpm/ui dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "tsup": "^8.3.0",
    "typescript": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "vitest": "^4.1.2"
  }
}

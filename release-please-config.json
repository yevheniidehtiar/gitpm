{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "include-component-in-tag": true,
  "pull-request-title-pattern": "chore: release${component} ${version}",
  "group-pull-request-title-pattern": "chore: release ${branch}",
  "packages": {
    "packages/core": {
      "package-name": "@gitpm/core",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/sync-github": {
      "package-name": "@gitpm/sync-github",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/sync-gitlab": {
      "package-name": "@gitpm/sync-gitlab",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/sync-jira": {
      "package-name": "@gitpm/sync-jira",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/cli": {
      "package-name": "@gitpm/cli",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/ui": {
      "package-name": "@gitpm/ui",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
